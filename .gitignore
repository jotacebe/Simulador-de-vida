# --- Python ---
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so

# --- Entornos Virtuales (Venv) ---
# Es vital no subir el entorno virtual al repositorio
venv/
.venv/
env/
bin/
include/
lib/
lib64/

# --- IDEs y Editores ---
.vscode/
.idea/
*.swp
*.swo

# --- Archivos del Sistema Operativo ---
.DS_Store
Thumbs.db
ehthumbs.db

# --- Archivos Sensibles / Configuración ---
# Si usas variables de entorno o credenciales, nunca las subas
.env
.flaskenv
secret_config.json

# --- Archivos generados por tu simulador ---
# Estos son los archivos que mencionaste que tu sistema exporta. 
# Generalmente no queremos subir la "historia" de cada ejecución de prueba.
simulation_metrics.json
data_historica.json
logs/
*.log